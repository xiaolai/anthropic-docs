{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xiaolai/claude-code-documentation-knowledge-autoupdated/schema/mcp.schema.json",
  "title": "Claude Code .mcp.json",
  "description": "Permissive schema for .mcp.json. The mcpServers object maps a server name to its config. The research agent tightens this over time as the MCP spec stabilises.",
  "type": "object",
  "additionalProperties": true,
  "required": ["mcpServers"],
  "properties": {
    "mcpServers": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "description": "stdio transport (default when 'command' is set).",
            "required": ["command"],
            "additionalProperties": true,
            "properties": {
              "type": { "type": "string", "enum": ["stdio"] },
              "command": { "type": "string" },
              "args": { "type": "array", "items": { "type": "string" } },
              "env": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "cwd": { "type": "string" }
            }
          },
          {
            "type": "object",
            "description": "http transport.",
            "required": ["type", "url"],
            "additionalProperties": true,
            "properties": {
              "type": { "type": "string", "enum": ["http"] },
              "url": { "type": "string", "format": "uri" },
              "headers": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          },
          {
            "type": "object",
            "description": "sse transport.",
            "required": ["type", "url"],
            "additionalProperties": true,
            "properties": {
              "type": { "type": "string", "enum": ["sse"] },
              "url": { "type": "string", "format": "uri" },
              "headers": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        ]
      }
    }
  }
}
